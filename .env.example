# OralCounsellor Environment Configuration
# Copy this file to .env and fill in your actual values

# 阿里百炼 (Alibaba Bailian) API Configuration
# 使用 OpenAI 兼容接口
DASHSCOPE_API_KEY=your_dashscope_api_key_here
ALIBABA_API_KEY=your_dashscope_api_key_here  # 兼容旧配置
ALIBABA_MODEL=qwen-plus
ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIBABA_MAX_TOKENS=2000
ALIBABA_TEMPERATURE=0.7
ALIBABA_TOP_P=0.8
ALIBABA_ENABLE_SEARCH=false

# OpenAI API Configuration (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Audio Configuration
AUDIO_SAMPLE_RATE=16000
AUDIO_TEMP_DIR=temp_audio
AUDIO_MAX_DURATION=300

# Model Configuration
# ASR_PROVIDER options: whisper, alibaba
# TTS_PROVIDER options: edge, alibaba
# LLM_PROVIDER options: alibaba, openai
WHISPER_MODEL=base
ASR_PROVIDER=whisper
TTS_PROVIDER=edge
LLM_PROVIDER=alibaba

# TTS Configuration
EDGE_TTS_VOICE=en-US-JennyNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%

# 阿里百炼 TTS 配置
ALIBABA_TTS_VOICE=中文女
ALIBABA_TTS_VOLUME=50
ALIBABA_TTS_SPEECH_RATE=1.0
ALIBABA_TTS_PITCH_RATE=1.0

# 增强聊天模块配置
# 会话管理
CHAT_MAX_HISTORY_LENGTH=50
CHAT_SESSION_TIMEOUT=3600
CHAT_AUTO_SAVE=true
CHAT_SAVE_INTERVAL=300
CHAT_MAX_SESSIONS=100
CHAT_CLEANUP_INTERVAL=86400

# 音频配置
AUDIO_MAX_RECORDING_DURATION=60
AUDIO_MIN_RECORDING_DURATION=1
AUDIO_SAMPLE_RATE=16000
AUDIO_AUTO_PLAY=true
AUDIO_PLAYBACK_SPEED=1.0
AUDIO_VOLUME=0.8
AUDIO_NOISE_THRESHOLD=0.1

# 主题生成配置
TOPIC_DEFAULT_DIFFICULTY=intermediate
TOPIC_MAX_RETRIES=3
TOPIC_CONTEXT_AWARE=true
TOPIC_AUTO_GENERATE=false
TOPIC_PREFERRED_CATEGORIES=daily,hobby,travel

# 用户界面配置
UI_DEFAULT_INPUT_MODE=text
UI_SHOW_HISTORY=false
UI_THEME=light
UI_LANGUAGE=zh-CN
UI_AUTO_SCROLL=true

# 缓存配置
TTS_CACHE_SIZE=1000
TTS_CACHE_TTL=3600
CHAT_CACHE_SIZE=500
CHAT_CACHE_TTL=1800
ENABLE_AUDIO_CACHE=true
AUDIO_CACHE_DIR=.cache/audio

# 性能优化配置
ENABLE_ASYNC_PROCESSING=true
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30
RETRY_ATTEMPTS=3
RETRY_DELAY=1.0

# 系统提示词配置（可选）
# CUSTOM_SYSTEM_PROMPT=You are Alex, a professional English conversation coach...
# TOPIC_SYSTEM_PROMPT=Generate conversation topics suitable for English learners...

# Web Interface Configuration
GRADIO_SHARE=false
GRADIO_PORT=7860
GRADIO_SERVER_NAME=127.0.0.1

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/oralcounsellor.log

# Development Configuration
# ENVIRONMENT options: development, production
DEBUG=false
ENVIRONMENT=development

# Cache Configuration
CACHE_DIR=.cache
MODEL_CACHE_DIR=data/models

# Security Configuration
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1